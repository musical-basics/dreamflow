  override draw(): void {
    const ctx = this.checkContext();
    this.setRendered();
    const clsAttribute = this.getAttribute('class');
    ctx.openGroup('flag' + (clsAttribute ? ' ' + clsAttribute : ''), this.getAttribute('id'));

